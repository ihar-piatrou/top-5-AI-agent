{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\SQLEXPRESS2019;Database=Top5Agent;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "OpenAI": {
    "ApiKey": "YOUR_OPENAI_API_KEY"
  },
  "Anthropic": {
    "ApiKey": "YOUR_ANTHROPIC_API_KEY"
  },
  "Pexels": {
    "ApiKey": "YOUR_PEXELS_API_KEY",
    "BaseUrl": "https://api.pexels.com/"
  },
  "Pipeline": {
    "DuplicateThreshold": 0.85,
    "Niches": [
      "cars",
      "health",
      "personal finance",
      "technology",
      "home improvement",
      "cooking",
      "fitness",
      "travel",
      "parenting",
      "productivity"
    ]
  },
  "Hangfire": {
    "DashboardPath": "/hangfire"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Warning"
    }
  },
  "AllowedHosts": "*"
}
